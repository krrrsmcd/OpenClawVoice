# Copy this file to .env and fill in your real values.
# Never commit .env — it holds secrets.

# --- ElevenLabs ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Cloudflare R2 ---
# Account ID is the subdomain in your S3 endpoint:
#   https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=openclaw-voice
# Public base URL for the bucket (no trailing slash), e.g. https://pub-xxxx.r2.dev
R2_PUBLIC_BASE_URL=

# Note: no Telegram token needed — OpenClaw's gateway owns the Telegram channel.
